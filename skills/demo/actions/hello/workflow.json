{
  "id": "hello",
  "name": "页面采集演示",
  "nodes": [
    {
      "id": "step-open",
      "type": "openPage",
      "name": "打开目标页面",
      "url": "{{targetUrl}}"
    },
    {
      "id": "step-wait",
      "type": "wait",
      "name": "等待页面加载",
      "ms": 1500
    },
    {
      "id": "step-extract",
      "type": "extract",
      "name": "采集页面信息",
      "var": "pageInfo"
    },
    {
      "id": "step-export",
      "type": "export",
      "name": "导出 JSON",
      "format": "json",
      "data": "pageInfo"
    }
  ]
}
